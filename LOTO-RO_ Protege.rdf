    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ActivityRequirement -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ActivityRequirement">
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:ValuesPossible>The knowledge, skills, or qualifications that a person must possess to perform a work activity safely.</rdfs:ValuesPossible>
        <rdfs:label>ActivityRequirements</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidOrTreatment -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidOrTreatment">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A medical or first-aid intervention provided in response to injuries sustained during an incident.</rdfs:comment>
        <rdfs:label>AidOrTreatment</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization">
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:ValuesPossible>Have, Have Not, Not Specified</rdfs:ValuesPossible>
        <rdfs:comment>Formal approval, permit, or permission granted to a person to perform tasks subject to LOTO or hazardous energy control procedures during an incident.</rdfs:comment>
        <rdfs:label>Authorization</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#generatesConsequence"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>Any condition, action, or circumstance that contributes to the occurrence or severity of a LOTO incident. Includes human, technological, and organizational factors.</rdfs:comment>
        <rdfs:label>Cause</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence">
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The actual injury, fatality, or material damage resulting from the occurrence of an incident.</rdfs:comment>
        <rdfs:label>Consequence</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#mitigatesRisk"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#protectsFromHazard"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A technical, procedural, or organizational measure implemented to reduce exposure to hazards or mitigate risks during work activities.</rdfs:comment>
        <rdfs:label>ControlMeasure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergyReleaseEvent -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergyReleaseEvent">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#triggers"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An unintended activation, movement, or discharge of hazardous energy resulting from loss of control of an energy source.</rdfs:comment>
        <rdfs:label>EnergyReleaseEvent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A form or origin of energy associated with a machine or system that can cause harm if unexpectedly released during a work activity.</rdfs:comment>
        <rdfs:label>EnergySource</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A condition, source, or situation with the inherent potential to cause injury or damage during a work activity.</rdfs:comment>
        <rdfs:label>Hazard</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HumanError -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HumanError">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A cause factor characterized by an unsafe action, omission, or decision made by a person during a work activity.</rdfs:comment>
        <rdfs:label>HumanError</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#InadequateSupervision -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#InadequateSupervision">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An organizational issue involving insufficient oversight, guidance, or enforcement of safety practices during work activities.</rdfs:comment>
        <rdfs:label>InadequateSupervision</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#InadequateTraining -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#InadequateTraining">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An organizational issue in which personnel lack the necessary knowledge or skills to perform activities safely.</rdfs:comment>
        <rdfs:label>InadequateTraining</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#carriedOutDuring"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasCauseFactor"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#resultsInConsequence"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A specific, unplanned occurrence during a work activity that results in injury, fatality, or material damage. Each incident is uniquely identified by its ID.</rdfs:comment>
        <rdfs:label>IncidentEvent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A physical mechanism used to isolate or indicate the locked or tagged-out state of an energy source on a machine or equipment, preventing unauthorized or accidental re-energization during maintenance or servicing activities.</rdfs:comment>
        <rdfs:label>LOTODevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedure -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedure">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasStep"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requires"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTORequirement"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The safety procedure standard used to isolate hazardous energy sources and ensure personnel safety before conducting maintenance activities in a LOTO incident (e.g., OSHA 1910.147).</rdfs:comment>
        <rdfs:label>LOTOProcedure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requiresAuthorization"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requiresControlMeasure"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A defined phase within a LOTO procedure, representing a discrete and mandatory step in the sequence of energy isolation and control activities.</rdfs:comment>
        <rdfs:label>LOTOProcedureStep</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTORequirement -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTORequirement">
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A mandatory rule or obligation defined by regulations that outlines how LOTO procedures must be applied or followed during incidents.</rdfs:comment>
        <rdfs:label>LOTORequirement</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasEnergySource"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasStatus"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasWorkArea"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#partOfPlant"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Plant"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A powered or mechanical system used to perform work functions and capable of generating hazardous conditions during operation.</rdfs:comment>
        <rdfs:label>Machine</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineComponent -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineComponent">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A physical part or subsystem of a machine whose function contributes to the machine&apos;s overall operation.</rdfs:comment>
        <rdfs:label>MachineComponent</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus">
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The operational or physical condition of a machine at a given point in time, including states relevant to energy isolation and LOTO procedures.</rdfs:comment>
        <rdfs:label>MachineStatus</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A cause factor related to organizational conditions that influence how work activities are planned, supervised, or executed.</rdfs:comment>
        <rdfs:label>OrganizationalIssue</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalUnit -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalUnit">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A structured part of an organization responsible for managing personnel, equipment, or work areas involved in activities or incidents.</rdfs:comment>
        <rdfs:label>OrganizationalUnit</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Penalty -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Penalty">
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A formal disciplinary or legal consequence applied when a violation of safety procedures or regulations is identified during a LOTO incident.</rdfs:comment>
        <rdfs:label>Penalty</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant">
        <Mid-:Upper-OntologyAlignment>BFO</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The person(s) present at the scene of the incident who held neither a supervisory nor a performer role at the time the incident occurred.</rdfs:comment>
        <rdfs:label>PersonParticipant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer">
        <Mid-:Upper-OntologyAlignment>BFO</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The person(s) who were directly performing the work activity at the time the incident occurred.</rdfs:comment>
        <rdfs:label>PersonPerformer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor">
        <Mid-:Upper-OntologyAlignment>BFO</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The person(s) who held a supervisory role over the work activity in which the incident occurred, regardless of whether they were physically present.</rdfs:comment>
        <rdfs:label>PersonSupervisor</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Plant -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Plant">
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A physical industrial facility that hosts machines, work areas, and activities where incidents may occur.</rdfs:comment>
        <rdfs:label>Plant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ProcedureDeficiency -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ProcedureDeficiency">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An organizational issue arising from safety procedures that are incomplete, unclear, or insufficiently defined.</rdfs:comment>
        <rdfs:label>ProcedureDeficiency</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ProtectiveDevice -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ProtectiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:comment>A physical control measure designed to prevent or limit contact with hazardous parts or energy sources.</rdfs:comment>
        <rdfs:label>IOF-Core</rdfs:label>
        <rdfs:label>ProtectiveDevice</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ProtectiveProcedure -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ProtectiveProcedure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An internal procedural control measure intended to ensure safe interaction with hazards, including rules governing proper behavior during work activities.</rdfs:comment>
        <rdfs:label>ProtectiveProcedure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ResourceOrTimePressure -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ResourceOrTimePressure">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <rdfs:comment>An organizational issue in which limited time, staffing, or resources influence unsafe decision-making or actions.</rdfs:comment>
        <rdfs:comment>iof-maint</rdfs:comment>
        <rdfs:label>ResourceOrTimePressure</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#riskFromHazard"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>The potential for harm arising from exposure to a hazard, considering both the likelihood of occurrence and the severity of consequences.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RoutineBypass -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RoutineBypass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An organizational issue characterized by the habitual or normalized circumvention of established safety controls or procedures.</rdfs:comment>
        <rdfs:label>RoutineBypass</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#SafetyCultureIssue -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#SafetyCultureIssue">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>An organizational issue reflecting shared attitudes or practices within an organization that undervalue or deprioritize safety requirements.</rdfs:comment>
        <rdfs:label>SafetyCultureIssue</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFault -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFault">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A cause factor arising from a malfunction, defect, or failure of a machine or its components.</rdfs:comment>
        <rdfs:label>TechnologicalFault</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Violation -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Violation">
        <rdfs:subClassOf>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#subjectToPenalty"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Penalty"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#violates"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTORequirement"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Signature</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A condition or event in which a required rule, procedure, or safety control is omitted, not applied, or deliberately bypassed during a LOTO activity.</rdfs:comment>
        <rdfs:label>Violation</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity">
        <Mid-:Upper-OntologyAlignment>iof-maint</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A task or operation performed within an industrial context, involving interaction between persons, equipment, and potential hazards.</rdfs:comment>
        <rdfs:label>WorkActivity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation -->

    <owl:Class rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#workAreaWithinPlant"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Plant"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <Mid-:Upper-OntologyAlignment>IOF-Core</Mid-:Upper-OntologyAlignment>
        <rdfs:comment>A defined physical location within a plant where work activities are performed and where incidents may occur.</rdfs:comment>
        <rdfs:label>WorkAreaLocation</rdfs:label>
    </owl:Class>
    


