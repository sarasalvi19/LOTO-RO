<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO/"
     xml:base="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:Mid-="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Mid-/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Mid-/Upper-OntologyAlignment -->

    <owl:AnnotationProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Mid-/Upper-OntologyAlignment"/>
    


    <!-- http://www.w3.org/2000/01/rdf-schema#ValuesPossible -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2000/01/rdf-schema#ValuesPossible"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#date -->

    <rdfs:Datatype rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#time -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#time"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#activityExposesToHazard -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#activityExposesToHazard">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
        <rdfs:comment>Specifies the hazard to which a work activity exposes personnel.</rdfs:comment>
        <rdfs:label>activityExposesToHazard</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#affectsActivity -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#affectsActivity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:comment>Specifies the work activity affected by an organizational issue.</rdfs:comment>
        <rdfs:label>affectsActivity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#affectsComponent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#affectsComponent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFault"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineComponent"/>
        <rdfs:comment>Specifies the machine component affected by a technological fault.</rdfs:comment>
        <rdfs:label>affectsComponent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#appliedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#appliedTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:comment>Specifies the machine on which the LOTO device is applied.</rdfs:comment>
        <rdfs:label>appliedTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#assignedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#assignedTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:comment>Specifies the PersonPerformer to whom the LOTO device is assigned.</rdfs:comment>
        <rdfs:label>assignedTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#associatedWithEnergy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#associatedWithEnergy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource"/>
        <rdfs:comment>Specifies the energy source associated with a hazard.</rdfs:comment>
        <rdfs:label>associatedWithEnergy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#belongsTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#belongsTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalUnit"/>
        <rdfs:comment>Specifies the organizational unit to which a PersonPerformer belongs.</rdfs:comment>
        <rdfs:label>belongsTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#bypassesControlMeasure -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#bypassesControlMeasure">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RoutineBypass"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:comment>Specifies the control measure that was bypassed as part of a routine bypass behavior.</rdfs:comment>
        <rdfs:label>bypassesControlMeasure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#carriedOutDuring -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#carriedOutDuring">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:comment>Specifies the work activity during which the incident occurred.</rdfs:comment>
        <rdfs:label>carriedOutDuring</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#doesNotFollowStep -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#doesNotFollowStep">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:comment>Specifies the LOTO procedure step that a PersonPerformer failed to follow.</rdfs:comment>
        <rdfs:label>doesNotFollowStep</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#exposesParticipantTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#exposesParticipantTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:comment>Specifies the risk to which a PersonParticipant is exposed during a work activity.</rdfs:comment>
        <rdfs:label>exposesParticipantTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#exposesPerformerTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#exposesPerformerTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:comment>Specifies the risk to which a PersonPerformer is exposed during a work activity.</rdfs:comment>
        <rdfs:label>exposesPerformerTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#exposesSupervisorTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#exposesSupervisorTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:comment>Specifies the risk to which a PersonSupervisor is exposed during a work activity.</rdfs:comment>
        <rdfs:label>exposesSupervisorTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#generatesConsequence -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#generatesConsequence">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:comment>Specifies the consequence generated by a cause factor.</rdfs:comment>
        <rdfs:label>generatesConsequence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#happensIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#happensIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:comment>Specifies the LOTO procedure step during which the consequence occurred.</rdfs:comment>
        <rdfs:label>happensIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasAuthorization -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasAuthorization">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization"/>
        <rdfs:comment>Specifies the authorization held by a PersonPerformer to perform LOTO-related tasks.</rdfs:comment>
        <rdfs:label>hasAuthorization</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasCauseFactor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasCauseFactor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <rdfs:comment>Specifies the cause factor(s) associated with an incident event.</rdfs:comment>
        <rdfs:label>hasCauseFactor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasComponent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasComponent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineComponent"/>
        <rdfs:comment>Specifies a component that is part of a machine.</rdfs:comment>
        <rdfs:label>hasComponent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasControlMeasure -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasControlMeasure">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:comment>Specifies the control measure required by a work activity that was not complied with during the incident.</rdfs:comment>
        <rdfs:label>hasControlMeasure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasEnergySource -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasEnergySource">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource"/>
        <rdfs:comment>Specifies the energy source associated with a machine.</rdfs:comment>
        <rdfs:label>hasEnergySource</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasHumanError -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasHumanError">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HumanError"/>
        <rdfs:comment>Specifies the human error(s) identified in an incident event.</rdfs:comment>
        <rdfs:label>hasHumanError</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasMachineStatusAtEvent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasMachineStatusAtEvent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus"/>
        <rdfs:comment>Specifies the operational status of the machine at the time of the incident event.</rdfs:comment>
        <rdfs:label>hasMachineStatusAtEvent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasOrganizationalIssue -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasOrganizationalIssue">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <rdfs:comment>Specifies the organizational issue(s) identified in an incident event.</rdfs:comment>
        <rdfs:label>hasOrganizationalIssue</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasParticipant -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasParticipant">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:comment>Specifies the PersonParticipant(s) present during the work activity.</rdfs:comment>
        <rdfs:label>hasParticipant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasRequirement -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasRequirement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ActivityRequirement"/>
        <rdfs:comment>Specifies the activity requirement that a PersonPerformer must satisfy.</rdfs:comment>
        <rdfs:label>hasRequirement</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasStatus -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasStatus">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus"/>
        <rdfs:comment>Specifies the operational status of a machine.</rdfs:comment>
        <rdfs:label>hasStatus</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasStep -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasStep">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedure"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:comment>Specifies the step composition of a LOTO procedure.</rdfs:comment>
        <rdfs:label>hasStep</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasTechnologicalFault -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasTechnologicalFault">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFault"/>
        <rdfs:comment>Specifies the technological fault identified in an incident event.</rdfs:comment>
        <rdfs:label>hasTechnologicalFault</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasWorkArea -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#hasWorkArea">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:comment>Specifies the work area location where a machine is installed or operated.</rdfs:comment>
        <rdfs:label>hasWorkArea</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#intendedToPreventConsequence -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#intendedToPreventConsequence">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:comment>Specifies the consequence that a LOTO procedure step is designed to prevent.</rdfs:comment>
        <rdfs:label>intendedToPreventConsequence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#involvesMachine -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#involvesMachine">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:comment>Specifies the machine involved in a work activity.</rdfs:comment>
        <rdfs:label>involvesMachine</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#involvesPerson -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#involvesPerson">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:comment>Specifies the PersonPerformer who was directly involved in the work activity at the time of the incident.</rdfs:comment>
        <rdfs:label>involvesPerson</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#isAddressedByStep -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#isAddressedByStep">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <rdfs:comment>Specifies the LOTO procedure step that addresses a particular cause of an incident.</rdfs:comment>
        <rdfs:label>isAddressedByStep</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#isRequiredByActivity -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#isRequiredByActivity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ActivityRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:comment>Specifies the work activity for which an activity requirement applies.</rdfs:comment>
        <rdfs:label>isRequiredByActivity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#leadsToViolation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#leadsToViolation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Violation"/>
        <rdfs:comment>Specifies the violation that an organizational issue contributed to producing.</rdfs:comment>
        <rdfs:label>leadsToViolation</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#locationexposesToHazard -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#locationexposesToHazard">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
        <rdfs:comment>Specifies the hazard present at a work area location.</rdfs:comment>
        <rdfs:label>locationexposesToHazard</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#managedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#managedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalUnit"/>
        <rdfs:comment>Specifies the organizational unit responsible for managing a work area location.</rdfs:comment>
        <rdfs:label>managedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#mitigatesRisk -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#mitigatesRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:comment>Specifies the risk mitigated by a control measure.</rdfs:comment>
        <rdfs:label>mitigatesRisk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#notFollowedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#notFollowedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:comment>Specifies the work activity in which a LOTO procedure step was not followed.</rdfs:comment>
        <rdfs:label>notFollowedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#occursAtWorkArea -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#occursAtWorkArea">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:comment>Specifies the work area location where the incident occurred.</rdfs:comment>
        <rdfs:label>occursAtWorkArea</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#partOfPlant -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#partOfPlant">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Plant"/>
        <rdfs:comment>Specifies that a machine is part of a plant</rdfs:comment>
        <rdfs:label>partOfPlant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#performedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#performedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:comment>Specifies the PersonPerformer who executed the work activity.</rdfs:comment>
        <rdfs:label>performedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#protectsFromHazard -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#protectsFromHazard">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
        <rdfs:comment>Specifies the hazard against which a control measure provides protection.</rdfs:comment>
        <rdfs:label>protectsFromHazard</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#releasesEnergyIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#releasesEnergyIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergyReleaseEvent"/>
        <rdfs:comment>Specifies the energy release event triggered by a machine.</rdfs:comment>
        <rdfs:label>releasesEnergyIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requires -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requires">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedure"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTORequirement"/>
        <rdfs:comment>Specifies the regulatory requirements of a LOTO procedure.</rdfs:comment>
        <rdfs:label>requires</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requiresAuthorization -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requiresAuthorization">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization"/>
        <rdfs:comment>Specifies the authorizations required to perform a LOTOProcedureStep.</rdfs:comment>
        <rdfs:label>requiresAuthorization</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requiresControlMeasure -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#requiresControlMeasure">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:comment>Specifies the control measure required by a LOTO procedure step.</rdfs:comment>
        <rdfs:label>requiresControlMeasure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#resultsInConsequence -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#resultsInConsequence">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:comment>Specifies the consequence resulting from an incident event.</rdfs:comment>
        <rdfs:label>resultsInConsequence</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#riskFromHazard -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#riskFromHazard">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hazard"/>
        <rdfs:comment>Specifies the hazard from which a risk is derived.</rdfs:comment>
        <rdfs:label>riskFromHazard</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#subjectToPenalty -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#subjectToPenalty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Violation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Penalty"/>
        <rdfs:comment>Assigns a formal penalty to a Violation.</rdfs:comment>
        <rdfs:label>subjectToPenalty</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#sufferedByParticipant -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#sufferedByParticipant">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:comment>Specifies whether the consequence was suffered by a PersonParticipant. To exist, PersonPartcipant must be the victim.</rdfs:comment>
        <rdfs:label>sufferedByParticipant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#sufferedByPerformer -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#sufferedByPerformer">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:comment>Specifies whether the consequence was suffered by the PersonPerformer.</rdfs:comment>
        <rdfs:label>sufferedByPerformer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#sufferedBySupervisor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#sufferedBySupervisor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:comment>Specifies whether the consequence was suffered by a PersonSupervisor.</rdfs:comment>
        <rdfs:label>sufferedBySupervisor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#supervisedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#supervisedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:comment>Specifies the PersonSupervisor responsible for overseeing a work activity.</rdfs:comment>
        <rdfs:label>supervisedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#supervises -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#supervises">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:comment>Specifies the PersonPerformer supervised by a PersonSupervisor.</rdfs:comment>
        <rdfs:label>supervises</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#takesPlaceIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#takesPlaceIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkActivity"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:comment>Specifies the work area location where the work activity took place.</rdfs:comment>
        <rdfs:label>takesPlaceIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#treatedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#treatedBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidOrTreatment"/>
        <rdfs:comment>Specifies the aid or treatment provided in response to a consequence.</rdfs:comment>
        <rdfs:label>treatedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#triggers -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#triggers">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergyReleaseEvent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:comment>Specifies the incident event triggered by an energy release event.</rdfs:comment>
        <rdfs:label>triggers</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#usesControlMeasure -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#usesControlMeasure">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:comment>Specifies the control measure used by a PersonPerformer during a work activity.</rdfs:comment>
        <rdfs:label>usesControlMeasure</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#violates -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#violates">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Violation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTORequirement"/>
        <rdfs:comment>Specifies the LOTORequirement that a Violation has breached.</rdfs:comment>
        <rdfs:label>violates</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#workAreaWithinPlant -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#workAreaWithinPlant">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Plant"/>
        <rdfs:comment>Specifies the plant in which a work area location is situated.</rdfs:comment>
        <rdfs:label>workAreaWithinPlant</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPlace -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPlace">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidOrTreatment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The physical location where aid or medical treatment was provided following the incident, as explicitly stated or clearly implied in the incident narrative.</rdfs:comment>
        <rdfs:label>AidPlace</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPromptness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPromptness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidOrTreatment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The timing of the aid or medical response relative to the incident, as described in the incident narrative.</rdfs:comment>
        <rdfs:label>AidPromptness</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidResponderRole -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidResponderRole">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidOrTreatment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The role of the person(s) who provided aid or treatment during the incident (e.g., coworker, supervisor, medical staff), if mentioned in the narrative.</rdfs:comment>
        <rdfs:label>AidResponderRole</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AutomationLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AutomationLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Machine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The level of automation of the plant or system involved in the incident, if mentioned in the narrative (e.g., manual, semi-automated, automated).</rdfs:comment>
        <rdfs:label>AutomationLevel</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Certified -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Certified">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LevelOfTraining"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConfinedSpace -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConfinedSpace">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the incident occurred in a confined space, as explicitly stated or clearly implied by the narrative.</rdfs:comment>
        <rdfs:label>ConfinedSpace</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConsequenceOutcome -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConsequenceOutcome">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Consequence"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The medical outcome of the incident for the affected person(s), based on injuries or damage explicitly described in the narrative.</rdfs:comment>
        <rdfs:label>ConsequenceOutcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasureAccessibility -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasureAccessibility">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ControlMeasure"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Describes whether the relevant control measure was accessible and usable at the time of the incident, according to the narrative.</rdfs:comment>
        <rdfs:label>ControlMeasureAccessibility</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Critical_risk -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Critical_risk">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskSeverity"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Distracted -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Distracted">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ErrorIntentionality -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ErrorIntentionality">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HumanError"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the unsafe action or omission described in the incident was intentional (true) or unintentional (false), based on narrative cues.</rdfs:comment>
        <rdfs:label>ErrorIntentionality</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ErrorMotivation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ErrorMotivation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HumanError"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The stated or implied reason behind the human error described in the incident (e.g., time pressure, lack of attention), if mentioned in the narrative.</rdfs:comment>
        <rdfs:label>ErrorMotivation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Fatal -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Fatal">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConsequenceOutcome"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Fatal_risk -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Fatal_risk">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskSeverity"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Fatigued -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Fatigued">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HeatCold -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#HeatCold">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The thermal condition of the work area at the time of the incident, if mentioned or implied in the narrative.</rdfs:comment>
        <rdfs:label>HeatCold</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hospital -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hospital">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPlace"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hospitalized -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Hospitalized">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConsequenceOutcome"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Immediate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Immediate">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPromptness"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Impaired -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Impaired">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentDate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentDate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The calendar date on which the described incident occurred, as explicitly stated in the narrative.</rdfs:comment>
        <rdfs:label>IncidentDate</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentDescription -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A textual description of the incident as reported in the source narrative, summarizing the sequence of events leading to the injury or damage.</rdfs:comment>
        <rdfs:label>IncidentDescription</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentTime -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentTime">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IncidentEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#time"/>
        <rdfs:comment>The time of day at which the incident occurred, as explicitly stated in the narrative.</rdfs:comment>
        <rdfs:label>IncidentTime</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IsRoutine -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IsRoutine">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Cause"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the cause factor described in the incident narrative is portrayed as routine or habitual (true) versus unusual or exceptional (false).</rdfs:comment>
        <rdfs:label>IsRoutine</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IsVictim -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#IsVictim">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates whether the Person directly suffered the physical consequences of the incident (true) or not (false).</rdfs:comment>
        <rdfs:label>IsVictim</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Layout -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Layout">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of the physical layout or configuration of the work area relevant to the incident, if provided in the narrative.</rdfs:comment>
        <rdfs:label>Layout</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LevelOfTraining -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LevelOfTraining">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The level of formal training of the Person in relation to the task or LOTO procedure, as explicitly stated or clearly implied in the narrative.</rdfs:comment>
        <rdfs:label>LevelOfTraining</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Lighting -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Lighting">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The lighting conditions in the work area during the incident, as described or implied in the narrative.</rdfs:comment>
        <rdfs:label>Lighting</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Minor_risk -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Minor_risk">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskSeverity"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Noise -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Noise">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The noise level in the work area at the time of the incident, if mentioned or implied in the narrative.</rdfs:comment>
        <rdfs:label>Noise</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Non-hospitalized -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Non-hospitalized">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#ConsequenceOutcome"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Non-immediate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Non-immediate">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPromptness"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#None_experience -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#None_experience">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonExperience"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#None_leveloftraining -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#None_leveloftraining">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LevelOfTraining"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Off-site -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Off-site">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#AidPlace"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PenaltyAmount -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PenaltyAmount">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Penalty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>The numerical monetary amount of any penalty imposed as a result of the incident or related violation, if specified in the narrative.</rdfs:comment>
        <rdfs:label>PenaltyAmount</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PenaltyType -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PenaltyType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Penalty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The type of penalty resulting from the incident or violation (e.g., administrative, disciplinary, legal), as described in the narrative.</rdfs:comment>
        <rdfs:label>PenaltyType</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonExperience -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonExperience">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The level of job or task experience of the Person, as described or implied in the incident narrative.</rdfs:comment>
        <rdfs:label>PersonExperience</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The psychological or cognitive state of the Person at the time of the incident (e.g., fatigued, stressed), if mentioned or clearly implied in the narrative.</rdfs:comment>
        <rdfs:label>PsycologicalStatus</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Regulation -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Regulation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The degree of regulatory enforcement or safety rule compliance observed in the work area, as described or implied in the incident narrative.</rdfs:comment>
        <rdfs:label>Regulation</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskProbability -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskProbability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The likelihood of the hazardous event occurring, as implied or described in the incident context.</rdfs:comment>
        <rdfs:label>RiskProbability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskSeverity -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskSeverity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The potential severity of harm associated with the identified risk, as described or implied in the incident narrative.</rdfs:comment>
        <rdfs:label>RiskSeverity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Role -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Role">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonParticipant"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonSupervisor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The formal job role or occupational function of the Person at the time of the incident.</rdfs:comment>
        <rdfs:label>Role</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Rushed -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Rushed">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Severe_risk -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Severe_risk">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#RiskSeverity"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Status -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Status">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The operational state of a LOTO device at the time of the incident, indicating whether it was correctly applied, absent, or improperly removed.</rdfs:comment>
        <rdfs:label>Status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Stressed -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Stressed">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PsycologicalStatus"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#SupervisionLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#SupervisionLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#PersonPerformer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The degree of supervision present over the PersonPerformer during the activity leading to the incident, as described in the narrative.</rdfs:comment>
        <rdfs:label>SupervisionLevel</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFaultAwareness -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFaultAwareness">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#TechnologicalFault"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Indicates whether the technological fault involved in the incident was known, partially known, or unknown to the organization before the incident occurred, according to the narrative.</rdfs:comment>
        <rdfs:label>TechnologicalFaultAwareness</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Visibility -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Visibility">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#WorkAreaLocation"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The visibility conditions in the work area during the incident (e.g., obstructed, clear), as described or implied in the narrative.</rdfs:comment>
        <rdfs:label>Visibility</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#adequate -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#adequate">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Lighting"/>
    </owl:DatatypeProperty>
    


