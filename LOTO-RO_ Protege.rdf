        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Bolted_slip_blind -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Bolted_slip_blind">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Bypass -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Bypass">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#OrganizationalIssue"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Chain -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Chain">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTODevice"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Chemical_energy -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Chemical_energy">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#DeEnergized -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#DeEnergized">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Electrical_energy -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Electrical_energy">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Energized -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Energized">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#MachineStatus"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Energy_source_isolation -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Energy_source_isolation">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Equipment_shutdown -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Equipment_shutdown">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Equipment_shutdown_preparation -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Equipment_shutdown_preparation">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#LOTOProcedureStep"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Gravity_energy -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Gravity_energy">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#EnergySource"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Have -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Have">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization"/>
    </owl:NamedIndividual>
    


    <!-- http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Have_not -->

    <owl:NamedIndividual rdf:about="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Have_not">
        <rdf:type rdf:resource="http://www.semanticweb.org/saras/ontologies/2026/0/LOTO-RO#Authorization"/>
